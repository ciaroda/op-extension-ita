{
  "manifest_version": 3,
  "name": "Gioco Organizzato Italia – Guida Registrazione",
  "short_name": "PFS/SFS Guida",
  "description": "Guida passo-passo in italiano per la registrazione su Paizo, Warhorn e RPG Chronicles.",
  "version": "1.0.0",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.paizo.com/*",
        "*://*.warhorn.net/*",
        "*://*.rpgchronicles.net/*"
      ],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PFS/SFS Guida"
  },
  "permissions": ["storage"],
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "icons/*.png"],
      "matches": [
        "*://*.paizo.com/*",
        "*://*.warhorn.net/*",
        "*://*.rpgchronicles.net/*"
      ]
    }
  ]
}
